# =============================================================================
# .env.uat.example — UAT (User Acceptance Testing) environment template
#
# Copy to /etc/ragbot/.env.uat (chmod 600, owner ragbot:ragbot) and fill in.
# UAT is the gate between dev and prod — values MUST be more conservative
# than dev (no debug, fail-loud secrets, real LB-aware proxies).
#
# Differences from .env.example:
#   - APP_ENV=uat              (NOT development; activates weak-secret validator)
#   - APP_DEBUG=false          (no stack traces leak)
#   - RAGBOT_DEV_TOKEN_*=false (no /api/ragbot/test/tokens/self mint)
#   - DATABASE_POOL_*          tuned for actual UAT traffic
#   - APP_TRUSTED_PROXIES      MUST be set (LB injects X-Forwarded-For)
#   - APP_CORS_ALLOWED_ORIGINS MUST include UAT admin web origin
#   - All API keys MUST be real UAT tenant keys (NOT shared with dev)
#   - TENANT_HMAC_SECRET       MUST be a real high-entropy secret (32+ bytes)
# =============================================================================

# === APP ===
APP_NAME=ragbot
APP_ENV=uat
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=3004
APP_VERSION=

# === JWT / Auth ===
RAGBOT_JWT_TTL_S=86400
# CRITICAL — must remain false on UAT (otherwise anyone on the LAN can
# mint a level-100 owner token via /api/ragbot/test/tokens/self).
RAGBOT_DEV_TOKEN_ENABLED=false
RAGBOT_DEV_TOKEN_ALLOW_NETWORK=false

# === DATABASE ===
# DATABASE_URL is the ADMIN DSN — owner role used by alembic and ops
# scripts. UAT must NOT use the postgres superuser. Use a dedicated
# `ragbot_uat` owner role with grants only on the ragbot schema.
DATABASE_URL=postgresql+asyncpg://ragbot_uat:CHANGE_ME@uat-pg.internal:5432/ragbot_uat
DATABASE_URL_SYNC=postgresql+psycopg2://ragbot_uat:CHANGE_ME@uat-pg.internal:5432/ragbot_uat
ALEMBIC_SQLALCHEMY_URL=postgresql+psycopg2://ragbot_uat:CHANGE_ME@uat-pg.internal:5432/ragbot_uat
# DATABASE_URL_APP is the RUNTIME DSN — non-superuser ragbot_app role
# created by alembic 0073. Required for tenant RLS to bind in UAT/prod.
DATABASE_URL_APP=postgresql+asyncpg://ragbot_app:CHANGE_ME@uat-pg.internal:5432/ragbot_uat
DB_SCHEMA=public
DB_SEARCH_PATH=public
# UAT typically lower concurrency than prod; tune after first load test.
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=5
DATABASE_POOL_RECYCLE=1800

# === REDIS ===
REDIS_URL=redis://uat-redis.internal:6379/0
REDIS_POOL_SIZE=20

# === REDIS STREAMS ===
STREAM_STREAM_PREFIX=ragbot

# === LLM (UAT-specific keys, NOT dev) ===
OPENAI_API_KEY=
# REQUIRED for OpenAI 5xx fallback — alembic 0070 seeds claude-haiku-4-5
# as the failover model on every generation binding. Empty key = router
# logs "fallback_unavailable" and re-raises the primary error.
ANTHROPIC_API_KEY=
COHERE_API_KEY=
LLM_MODEL=gpt-4.1-mini

# === EMBEDDING ===
EMBEDDING_MODEL_NAME=jina-embeddings-v3
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL_VERSION=v3

# === MULTI-PROVIDER KEY POOL ===
# Canonical key map for UAT. Each provider gets its own UAT-specific
# key — DO NOT reuse dev keys (separate tenant scope, separate rate
# limits). Lists allow hot rotation without restart.
# Example: PROVIDER_API_KEYS_JSON={"jina_ai":["jina_uat_xxx"],"openai":["sk-uat-xxx"]}
PROVIDER_API_KEYS_JSON=

# === REVERSE PROXY / CORS — REQUIRED ON UAT ===
# UAT runs behind nginx / haproxy / LB. List the LB's internal IP(s)
# here so rate-limit + audit log use real client IP via X-Forwarded-For.
# Empty list on UAT = bug (all clients appear to come from LB IP).
APP_TRUSTED_PROXIES=["10.0.0.1"]

# UAT admin web origin must be listed or browser clients get CORS errors.
APP_CORS_ALLOWED_ORIGINS=["https://uat-admin.your-domain.example"]

# === OCR ===
OCR_PROVIDER=docling

# === AUTH ===
JWT_PUBLIC_KEY_PATH=/etc/ragbot/keys/jwt_public.pem
JWT_PRIVATE_KEY_PATH=/etc/ragbot/keys/jwt_private.pem
JWT_ALGORITHM=RS256
JWT_ISSUER=ragbot-uat
JWT_AUDIENCE=ragbot-uat-clients

# === SECRETS — MUST be real on UAT ===
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
# The "change-me-in-prod" placeholder will fail startup preflight when
# APP_ENV != development.
TENANT_HMAC_SECRET=
PROMPT_CANARY_TOKEN=

# === OBSERVABILITY ===
LOG_LEVEL=INFO
LOG_FORMAT=json
PROMETHEUS_METRICS_PATH=/metrics

# OTEL recommended on UAT for tail-latency analysis. Point at the
# UAT collector (not localhost — that won't exist in container).
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://uat-otel.internal:4318

# === PARSER ENGINE ===
RAGBOT_PARSER_ENGINE=docling

# === RERANKER ===
CO_API_KEY=

# === RAG DEFAULTS — match prod-equivalent system_config seed ===
DEFAULT_TOP_K=20
DEFAULT_RERANK_TOP_N=10
DEFAULT_CHUNK_SIZE=1024
DEFAULT_CHUNK_OVERLAP=128
SEMANTIC_CACHE_THRESHOLD=0.97
MAX_ITERATION_CAP=3
DEBOUNCE_WINDOW_MS=800

# === SCRIPTS ===
# scripts/test_rooms*.py uses this when hitting the UAT instance.
RAGBOT_BASE_URL=https://uat-api.your-domain.example

# Generic UAT smoke bot (override per tenant in workspace).
RAGBOT_TEST_BOT_ID=
