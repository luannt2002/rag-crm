# === APP ===
APP_NAME=ragbot
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0

# === JWT / Auth (Sprint 12B P0 critical security fix) ===
# Service-token TTL in seconds (default 86400 = 24h). Lower = smaller
# blast radius if a token leaks; higher = less re-issue churn.
RAGBOT_JWT_TTL_S=86400
# Dev-only owner-level token endpoint /api/ragbot/test/tokens/self.
# Returns a level-100 token. MUST be false in production.
RAGBOT_DEV_TOKEN_ENABLED=false
# Allow non-loopback callers to mint dev tokens. ONLY enable on a
# trusted private LAN (jumpbox, internal staging). NEVER public.
RAGBOT_DEV_TOKEN_ALLOW_NETWORK=false
# Optional int tenant id baked into the dev token so middleware
# cross-tenant guard works. Leave unset for unscoped (system) tokens.
# RAGBOT_DEV_TOKEN_TENANT_ID=1


# === DATABASE ===
# DATABASE_URL is the ADMIN DSN — superuser/owner role used by alembic
# migrations and ops scripts. NEVER point the runtime app at this DSN
# in production: superuser connections silently bypass RLS.
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/ragbot
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:your_password@localhost:5432/ragbot
ALEMBIC_SQLALCHEMY_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/ragbot
# DATABASE_URL_APP is the RUNTIME DSN — non-superuser ragbot_app role
# created by alembic 0073. Required for tenant RLS to bind. Local-only
# fallback: leave unset and export RAGBOT_ALLOW_SUPERUSER_RUNTIME=1 to
# fall back to DATABASE_URL with a structured warning (RLS disabled).
DATABASE_URL_APP=postgresql+asyncpg://ragbot_app:CHANGEME@localhost:5432/ragbot
DB_SCHEMA=public
DB_SEARCH_PATH=public
# P25-A7: DB pool sized for ~500 concurrent chats (each holds 6-10
# sessions). 50+50=100 hard cap. Postgres max_connections must be ≥150
# (100 pool + headroom for workers + manual ops).
# pool_timeout=5 — fail fast, don't hold request 30s waiting for a
# free conn.
DATABASE_POOL_SIZE=50
DATABASE_MAX_OVERFLOW=50
DATABASE_POOL_TIMEOUT=5
DATABASE_POOL_RECYCLE=1800

# === REDIS ===
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# === REDIS STREAMS ===
STREAM_STREAM_PREFIX=ragbot

# === LLM ===
OPENAI_API_KEY=sk-your-key-here
# REQUIRED for OpenAI 5xx fallback — alembic 0070 seeds claude-haiku-4-5
# as the failover model on every generation binding. Empty key = router
# logs "fallback_unavailable" and re-raises the primary error.
ANTHROPIC_API_KEY=
COHERE_API_KEY=
LLM_MODEL=gpt-4.1-mini

# === LM Studio self-hosted endpoint (optional benchmark / swap target) ===
# When set, scripts/wave_g_lmstudio_benchmark.py and the LM Studio swap
# pilot read these to compare candidate models against the canonical
# OpenAI / ZeroEntropy production binding. Default empty = pilot scripts
# refuse to run (no secret hard-coded anywhere).
LMSTUDIO_BASE_URL=
LMSTUDIO_API_KEY=

# === EMBEDDING (cloud API via LiteLLM) ===
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_MODEL_VERSION=v1

# === OCR ===
OCR_PROVIDER=docling

# === AUTH ===
JWT_PUBLIC_KEY_PATH=
JWT_PRIVATE_KEY_PATH=
JWT_ALGORITHM=RS256
JWT_ISSUER=ragbot
JWT_AUDIENCE=ragbot-clients

# === SECRETS ===
TENANT_HMAC_SECRET=change-me-in-prod
PROMPT_CANARY_TOKEN=

# === OBSERVABILITY ===
LOG_LEVEL=INFO
LOG_FORMAT=json
PROMETHEUS_METRICS_PATH=/metrics
# Operator-issued Bearer token guarding /metrics (master report Finding #3).
# Unset = endpoint stays open for backward compat (dev / loopback).
# Set in UAT/prod and configure the Prometheus scraper with the matching
# `bearer_token` so external probes can't harvest internal metrics.
# RAGBOT_METRICS_AUTH_TOKEN=change-me-in-prod

# Set to "true" to enable OpenTelemetry tracing (requires OTLP collector).
# Default off — tracing not required for normal ops, adds ~5-10ms/request.
OTEL_ENABLED=false

# === PARSER ENGINE ===
# Engines (fallback chain on ImportError: kreuzberg -> docling -> simple):
#   "kreuzberg" = layout-aware, F1 ~91% parity with Docling, ~9x faster,
#                 ~71MB install. Default post AdapChunk Wave C2.
#                 Install: pip install kreuzberg
#   "docling"   = layout-aware parser, heavier (~1.5GB). pip install docling
#   "simple"    = stdlib-only fallback, no layout extraction
RAGBOT_PARSER_ENGINE=kreuzberg

# === RERANKER ===
# Cohere key alias. LiteLLM accepts either env var name (we check both
# COHERE_API_KEY and CO_API_KEY at startup preflight).
CO_API_KEY=

# === RAG DEFAULTS ===
# Keep aligned with system_config seed values (migration 0020).
DEFAULT_TOP_K=20
DEFAULT_RERANK_TOP_N=5
DEFAULT_CHUNK_SIZE=1024
DEFAULT_CHUNK_OVERLAP=128
SEMANTIC_CACHE_THRESHOLD=0.97
MAX_ITERATION_CAP=3
DEBOUNCE_WINDOW_MS=800

# === SCRIPTS ===
# Base URL used by scripts/test_rooms.py when hitting the running
# ragbot instance. Override per-env; default assumes local uvicorn.
RAGBOT_BASE_URL=http://localhost:3004

# Test harness target bot id (generic default; override per tenant).
# Consumed by scripts/test_rooms*.py, scripts/evaluate_ragas.py,
# scripts/generate_golden_set.py, scripts/test_bot_conversation.py,
# scripts/test_bot_smoke.py. Keep value domain-neutral.
RAGBOT_TEST_BOT_ID=test-bot-v1

# === MULTI-PROVIDER KEY POOL (canonical) ===
# Canonical multi-provider key map. Replaces single-key envs as the
# source of truth — single-key envs (EMBEDDING_JINA_API_KEY_PRIMARY,
# RERANKER_JINA_API_KEY_PRIMARY, etc.) seed only providers not already
# declared here.
# Format: JSON object, provider code → list of API keys (rotation pool).
# Example (JSON-encoded for env var):
# PROVIDER_API_KEYS_JSON={"jina_ai":["jina_xxx","jina_yyy"],"openai":["sk-xxx"]}
PROVIDER_API_KEYS_JSON=

# === REVERSE PROXY / CORS (UAT/prod) ===
# JSON list of trusted proxy IPs. Required when behind a load balancer
# so IP rate-limiting uses the real client IP via X-Forwarded-For
# instead of the LB's IP. Empty list = trust no proxy (dev default).
APP_TRUSTED_PROXIES=[]

# JSON list of allowed CORS origins for browser clients. Empty list
# disables CORS entirely (server-to-server only). Must include the
# UAT/prod web admin origin when browser clients connect.
APP_CORS_ALLOWED_ORIGINS=[]
