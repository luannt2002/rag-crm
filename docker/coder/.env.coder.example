# Coder team local env — copy to .env.coder và edit khi cần
# DO NOT commit .env.coder (đã trong .gitignore via .env*)

# ── DB / Cache ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:coder_dev_local@localhost:5432/ragbot_v2_dev
DATABASE_URL_APP=postgresql+asyncpg://postgres:coder_dev_local@localhost:5432/ragbot_v2_dev
REDIS_URL=redis://localhost:6379/1

# ── Bypass for dev runtime (RLS dead until T1.S1b ships ragbot_app role) ──
RAGBOT_ALLOW_SUPERUSER_RUNTIME=1

# ── External API (BYO keys) ────────────────────────────────
OPENAI_API_KEY=
RERANKER_JINA_API_KEY=
ANTHROPIC_API_KEY=

# ── App settings ───────────────────────────────────────────
RAGBOT_ENV=coder-dev
RAGBOT_BASE_URL=http://localhost:3004
LOG_LEVEL=INFO

# ── Coder load-test only (T3 anti-abuse bypass) ────────────
RAGBOT_LOADTEST_BYPASS_TOKEN=
